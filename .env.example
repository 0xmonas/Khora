# AI — Option A: Vertex AI (recommended, higher rate limits)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global

# A1: Local dev — file-based service account key
GOOGLE_APPLICATION_CREDENTIALS=./keys/your-service-account.json

# A2: Vercel / serverless — base64-encoded service account key
# GOOGLE_SERVICE_ACCOUNT_KEY=   # cat keys/your-key.json | base64

# AI — Option B: AI Studio (fallback, lower rate limits)
GEMINI_API_KEY=

# Wallet & NFT Contract
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_BOOA_NFT_ADDRESS=
NEXT_PUBLIC_BOOA_NFT_ADDRESS_TESTNET=

# SIWE Session (iron-session, 32+ chars)
SESSION_SECRET=