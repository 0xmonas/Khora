# AI — Option A: Vertex AI (recommended, higher rate limits)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global

# A1: Local dev — file-based service account key
GOOGLE_APPLICATION_CREDENTIALS=./keys/your-service-account.json

# A2: Vercel / serverless — base64-encoded service account key
# GOOGLE_SERVICE_ACCOUNT_KEY=   # cat keys/your-key.json | base64

# AI — Option B: AI Studio (fallback, lower rate limits)
GEMINI_API_KEY=

# Wallet & NFT Contract
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_BOOA_NFT_ADDRESS=
NEXT_PUBLIC_BOOA_NFT_ADDRESS_TESTNET=

# SIWE Session (iron-session, 32+ chars)
SESSION_SECRET=

# Upstash Redis (rate limiting + metadata cache)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Replicate (FLUX image generation)
REPLICATE_API_TOKEN=

# AI Model Overrides (optional — defaults are set in code)
# GEMINI_TEXT_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_CHAT_MODEL=gemini-3.1-flash-lite-preview
# REPLICATE_FLUX_MODEL=0xmonas/y2:...

# Cloudflare Turnstile (bot protection for waitlist)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Waitlist Admin (used to open/close waitlist and export addresses)
WAITLIST_ADMIN_SECRET=HOLDERS_CHAT_INVITE_URL=
